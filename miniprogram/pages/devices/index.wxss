page {
  min-height: 100%;
  background: #f6faf9;
  color: #18231f;
  font-family: PingFang SC, Helvetica Neue, Arial, sans-serif;
}

.devices-page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 24rpx 24rpx 56rpx;
}

.hero-card {
  border: 1rpx solid #dcecee;
  border-radius: 18rpx;
  background: #fff;
  padding: 26rpx;
  margin-bottom: 22rpx;
  box-shadow: 0 14rpx 34rpx rgba(10, 80, 94, 0.07);
}

.hero-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.hero-copy {
  min-width: 0;
}

.hero-actions {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  column-gap: 12rpx;
}

.about-button,
.logout-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 104rpx;
  height: 60rpx;
  box-sizing: border-box;
  border-radius: 30rpx;
  font-size: 26rpx;
  line-height: 1;
}

.about-button {
  border: 1rpx solid #b8dee3;
  background: #e7f7f7;
  color: #087d91;
  font-weight: 600;
}

.page-kicker {
  color: #087d91;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 32rpx;
}

.page-title {
  margin-top: 4rpx;
  font-size: 44rpx;
  font-weight: 600;
  line-height: 58rpx;
}

.page-subtitle {
  margin-top: 2rpx;
  color: #65736e;
  font-size: 25rpx;
  line-height: 34rpx;
}

.logout-button {
  border: 1rpx solid #cfe2e5;
  background: #f7fbfb;
  color: #566762;
}

.summary-row {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  column-gap: 18rpx;
}

.summary-item {
  min-height: 126rpx;
  box-sizing: border-box;
  border: 1rpx solid #e2eceb;
  border-radius: 16rpx;
  background: #f9fcfb;
  padding: 22rpx;
}

.summary-item.accent {
  border-color: #cce9ec;
  background: #eefafa;
}

.summary-value {
  color: #087d91;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 52rpx;
}

.summary-label {
  margin-top: 8rpx;
  color: #687771;
  font-size: 25rpx;
}

.bind-panel {
  box-sizing: border-box;
  border: 1rpx solid #e1ebe6;
  border-radius: 18rpx;
  background: #fff;
  padding: 30rpx;
  margin-bottom: 34rpx;
  box-shadow: 0 12rpx 30rpx rgba(35, 58, 49, 0.05);
}

.bind-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.section-title {
  color: #1e2a25;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 44rpx;
}

.section-subtitle {
  margin-top: 4rpx;
  color: #72817b;
  font-size: 24rpx;
  line-height: 34rpx;
}

.scan-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 60rpx;
  box-sizing: border-box;
  border-radius: 30rpx;
  background: #e7f7f7;
  color: #087d91;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1;
}

.form-row {
  display: flex;
  align-items: center;
  min-height: 96rpx;
  border-bottom: 1rpx solid #edf2ef;
}

.form-label {
  width: 150rpx;
  color: #63726c;
  font-size: 26rpx;
}

.form-input {
  flex: 1;
  min-width: 0;
  height: 72rpx;
  color: #18231f;
  font-size: 28rpx;
}

.picker-row {
  border-bottom: 0;
}

.picker-value {
  flex: 1;
  color: #087d91;
  font-size: 28rpx;
  text-align: right;
}

.primary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 82rpx;
  margin-top: 22rpx;
  box-sizing: border-box;
  border-radius: 12rpx;
  background: #087d91;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1;
  box-shadow: 0 12rpx 22rpx rgba(8, 125, 145, 0.18);
}

.section-header {
  margin-bottom: 18rpx;
}

.filter-scroll {
  width: 100%;
  white-space: nowrap;
  margin-bottom: 20rpx;
}

.filter-track {
  display: inline-flex;
  column-gap: 14rpx;
  padding-right: 28rpx;
}

.filter-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 104rpx;
  height: 58rpx;
  padding: 0 22rpx;
  border: 1rpx solid #dce7e2;
  border-radius: 29rpx;
  background: #fff;
  color: #607069;
  font-size: 25rpx;
}

.filter-chip.active {
  border-color: #087d91;
  background: #e7f7f7;
  color: #087d91;
  font-weight: 600;
}

.empty-state {
  min-height: 236rpx;
  box-sizing: border-box;
  border: 1rpx dashed #c9d7d0;
  border-radius: 16rpx;
  background: #fff;
  text-align: center;
  padding-top: 62rpx;
}

.empty-title {
  color: #2b3833;
  font-size: 30rpx;
  font-weight: 600;
}

.empty-text {
  margin-top: 10rpx;
  color: #7c8984;
  font-size: 25rpx;
}

.device-card {
  border: 1rpx solid #e1ebe6;
  border-radius: 18rpx;
  background: #fff;
  margin-bottom: 18rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 24rpx rgba(35, 58, 49, 0.05);
}

.device-main {
  display: flex;
  align-items: center;
  padding: 24rpx;
}

.device-icon {
  width: 76rpx;
  height: 76rpx;
  border-radius: 18rpx;
  background: #087d91;
  flex-shrink: 0;
  overflow: hidden;
}

.device-icon-image {
  background: #e8f7f3;
}

.device-icon.watering {
  background: #1f8f68;
}

.device-icon.sensor {
  background: #2d7dd2;
}

.device-icon.light {
  background: #d99a21;
}

.device-icon.socket {
  background: #7a6aef;
}

.device-icon.gateway {
  background: #365f6b;
}

.device-copy {
  flex: 1;
  min-width: 0;
  margin-left: 20rpx;
}

.device-name {
  color: #1f2b26;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 40rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.device-meta {
  margin-top: 8rpx;
  color: #71807a;
  font-size: 24rpx;
  line-height: 32rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-pill {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 46rpx;
  min-width: 74rpx;
  padding: 0 16rpx;
  border-radius: 23rpx;
  background: #e7f7f7;
  color: #087d91;
  font-size: 23rpx;
  line-height: 1;
  text-align: center;
}

.status-pill.offline {
  background: #f0f2f1;
  color: #7c8984;
}

.device-actions {
  display: flex;
  justify-content: flex-end;
  column-gap: 12rpx;
  border-top: 1rpx solid #edf2ef;
  padding: 14rpx 20rpx;
}

.text-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 108rpx;
  height: 54rpx;
  box-sizing: border-box;
  border-radius: 10rpx;
  background: #e7f7f7;
  color: #087d91;
  font-size: 24rpx;
  line-height: 1;
}

.text-button.danger {
  background: #fff0ec;
  color: #c2573d;
}