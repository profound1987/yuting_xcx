<view class="devices-page">
  <view class="hero-card">
    <view class="hero-top">
      <view class="hero-copy">
        <view class="page-kicker">云汀智家</view>
        <view class="page-title">设备管理</view>
        <view class="page-subtitle">{{phoneMasked}}</view>
      </view>
      <view class="hero-actions">
        <view class="about-button" bindtap="openAbout">关于</view>
        <view class="logout-button" bindtap="logout">退出</view>
      </view>
    </view>

    <view class="summary-row">
      <view class="summary-item">
        <view class="summary-value">{{deviceCount}}</view>
        <view class="summary-label">已绑定</view>
      </view>
      <view class="summary-item accent">
        <view class="summary-value">{{onlineCount}}</view>
        <view class="summary-label">在线设备</view>
      </view>
    </view>
  </view>

  <view class="bind-panel">
    <view class="bind-header">
      <view>
        <view class="section-title">配置设备</view>
        <view class="section-subtitle">输入设备号或扫描设备二维码，完成配网后再加入我的设备</view>
      </view>
    </view>
    <view class="form-row device-no-row">
      <view class="form-label">设备号</view>
      <input class="form-input" placeholder="例如 YT-AW-0004B-C11F" value="{{deviceNo}}" bindinput="onDeviceNoInput" />
      <view class="scan-button inline" bindtap="scanDeviceCode">扫码</view>
    </view>
    <view class="form-row">
      <view class="form-label">设备 PIN</view>
      <input class="form-input" type="number" maxlength="8" placeholder="设备标签上的 4-8 位 PIN" value="{{devicePin}}" bindinput="onDevicePinInput" />
    </view>
    <view class="form-row">
      <view class="form-label">设备名称</view>
      <input class="form-input" placeholder="例如 阳台浇水" value="{{deviceName}}" bindinput="onDeviceNameInput" />
    </view>
    <view class="device-hint">设备类型会根据设备号自动识别；PIN 是近场持有证明，没有 PIN 不能配网。</view>
    <view class="primary-button" bindtap="configureDevice">配置设备</view>
  </view>

  <view class="section-header">
    <view class="section-title">我的设备</view>
  </view>
  <scroll-view class="filter-scroll" scroll-x="true" enhanced="true" show-scrollbar="false">
    <view class="filter-track">
      <view wx:for="{{filters}}" wx:key="value" data-value="{{item.value}}" class="filter-chip {{activeFilter === item.value ? 'active' : ''}}" bindtap="onFilterTap">{{item.label}}</view>
    </view>
  </scroll-view>

  <view wx:if="{{visibleDevices.length === 0}}" class="empty-state">
    <view class="empty-title">暂无设备</view>
    <view class="empty-text">配置成功后会显示在这里</view>
  </view>

  <view wx:for="{{visibleDevices}}" wx:key="id" class="device-card">
    <view class="device-main" data-id="{{item.id}}" bindtap="openDevice">
      <image wx:if="{{item.type === 'watering'}}" class="device-icon device-icon-image" src="../../images/water-thumb.jpg" mode="aspectFill"></image>
      <view wx:else class="device-icon {{item.type}}"></view>
      <view class="device-copy">
        <view class="device-name">{{item.name}}</view>
        <view class="device-meta">{{item.typeLabel}} · {{item.deviceNo}}</view>
      </view>
      <view class="status-pill {{item.online === false ? 'offline' : ''}} {{item.networkState === 'not_provisioned' || item.provisionState === 'not_provisioned' ? 'unprovisioned' : ''}}">{{item.status}}</view>
    </view>
    <view class="device-actions">
      <view class="text-button" data-id="{{item.id}}" bindtap="openDevice">管理</view>
      <view wx:if="{{item.networkState === 'not_provisioned' || item.provisionState === 'not_provisioned' || item.canConfigure}}" class="text-button configure" data-id="{{item.id}}" bindtap="configureStoredDevice">配网</view>
      <view class="text-button danger" data-id="{{item.id}}" bindtap="deleteDevice">解绑</view>
    </view>
  </view>
</view>