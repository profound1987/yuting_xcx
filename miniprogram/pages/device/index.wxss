page {
  min-height: 100%;
  background: #f6faf9;
  color: #18231f;
  font-family: PingFang SC, Helvetica Neue, Arial, sans-serif;
}

.device-page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 28rpx 28rpx 56rpx;
}

.device-hero {
  border-radius: 18rpx;
  background: #fff;
  border: 1rpx solid #e1ebe6;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 14rpx 34rpx rgba(10, 80, 94, 0.07);
}

.device-head {
  display: flex;
  align-items: center;
}

.device-icon {
  width: 78rpx;
  height: 78rpx;
  border-radius: 18rpx;
  background: #087d91;
  flex-shrink: 0;
  overflow: hidden;
}

.device-icon-image {
  background: #e8f7f3;
}

.device-icon.sensor {
  background: #2d7dd2;
}

.device-icon.light {
  background: #d99a21;
}

.device-icon.socket {
  background: #7a6aef;
}

.device-icon.gateway {
  background: #365f6b;
}

.device-copy {
  flex: 1;
  min-width: 0;
  margin-left: 20rpx;
}

.device-name {
  color: #1e2a25;
  font-size: 34rpx;
  font-weight: 600;
  line-height: 44rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.device-meta {
  margin-top: 8rpx;
  color: #6d7b75;
  font-size: 24rpx;
  line-height: 32rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-pill {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 48rpx;
  min-width: 78rpx;
  padding: 0 16rpx;
  border-radius: 24rpx;
  background: #e7f7f7;
  color: #087d91;
  font-size: 24rpx;
  line-height: 1;
  text-align: center;
}

.status-pill.running {
  background: #fff2d8;
  color: #aa6f00;
}

.status-pill.offline {
  background: #f0f2f1;
  color: #7c8984;
}

.status-pill.unprovisioned {
  background: #fff8e6;
  color: #9a6a00;
}

.hero-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  column-gap: 18rpx;
  margin-top: 28rpx;
}

.hero-item {
  min-height: 112rpx;
  border-radius: 14rpx;
  background: #f6faf8;
  padding: 20rpx;
}

.hero-label {
  color: #75837d;
  font-size: 24rpx;
  line-height: 32rpx;
}

.hero-value {
  margin-top: 10rpx;
  color: #087d91;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 38rpx;
}

.hero-value.small {
  color: #26342f;
  font-size: 24rpx;
  line-height: 34rpx;
}

.hero-value.muted {
  color: #7c8984;
}

.mode-tabs {
  display: flex;
  column-gap: 14rpx;
  row-gap: 14rpx;
  margin-bottom: 22rpx;
}

.mode-tab {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
  height: 72rpx;
  border: 1rpx solid #dce7e2;
  border-radius: 12rpx;
  background: #fff;
  color: #63736c;
  font-size: 27rpx;
  line-height: 1;
  text-align: center;
}

.mode-tab.active {
  border-color: #087d91;
  background: #e7f7f7;
  color: #087d91;
  font-weight: 600;
}

.mode-tab.disabled {
  border-color: #e2e8e5;
  background: #f4f7f6;
  color: #a0aba6;
}

.config-panel {
  border: 1rpx solid #e1ebe6;
  border-radius: 16rpx;
  background: #fff;
  padding: 28rpx;
  margin-bottom: 22rpx;
}

.section-title {
  color: #1e2a25;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 44rpx;
  margin-bottom: 18rpx;
}

.fill-sentence {
  color: #2b3934;
  font-size: 30rpx;
  line-height: 74rpx;
}

.fill-sentence.compact {
  line-height: 72rpx;
}

.inline-input {
  display: inline-block;
  width: 116rpx;
  height: 58rpx;
  min-height: 58rpx;
  margin: 0 8rpx;
  border: 1rpx solid #cddbd5;
  border-radius: 10rpx;
  background: #f8fbfa;
  color: #087d91;
  font-size: 30rpx;
  line-height: 58rpx;
  text-align: center;
  vertical-align: middle;
}

.inline-input.readonly {
  border-color: #dfe7e4;
  background: #f1f4f3;
  color: #8a9691;
}

.save-button,
.primary-button,
.danger-button {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  width: 100%;
  height: 84rpx;
  border-radius: 12rpx;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1;
}

.save-button,
.primary-button {
  background: #087d91;
}

.danger-button {
  background: #c2573d;
}

.save-button.disabled,
.primary-button.disabled,
.danger-button.disabled {
  background: #c5ceca;
  box-shadow: none;
}

.manual-actions {
  margin-top: 24rpx;
}

.run-box {
  margin-top: 22rpx;
  border-radius: 12rpx;
  background: #f6faf8;
  padding: 18rpx;
}

.run-label {
  margin-bottom: 14rpx;
  color: #52615b;
  font-size: 25rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  min-height: 72rpx;
  border-top: 1rpx solid #edf2ef;
  align-items: center;
}

.info-label {
  color: #687771;
  font-size: 26rpx;
}

.info-value {
  color: #1e2a25;
  font-size: 27rpx;
  max-width: 430rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.notice-panel {
  border: 1rpx solid #d6ebe7;
  border-radius: 16rpx;
  background: #eefaf7;
  padding: 22rpx 24rpx;
  margin-bottom: 22rpx;
}

.notice-panel.warning {
  border-color: #f0dba8;
  background: #fff8e6;
}

.notice-panel.danger {
  border-color: #efc6ba;
  background: #fff0ed;
}

.notice-title {
  color: #1e2a25;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 38rpx;
}

.notice-text {
  margin-top: 8rpx;
  color: #5f6f69;
  font-size: 24rpx;
  line-height: 34rpx;
}

.inline-configure-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 68rpx;
  margin-top: 18rpx;
  border-radius: 12rpx;
  background: #087d91;
  color: #fff;
  font-size: 27rpx;
  font-weight: 600;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.section-head .section-title {
  margin-bottom: 0;
}

.command-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  background: rgba(15, 31, 27, 0.45);
}

.command-dialog {
  box-sizing: border-box;
  width: 100%;
  max-width: 620rpx;
  border-radius: 22rpx;
  background: #fff;
  padding: 42rpx 34rpx 34rpx;
  text-align: center;
  box-shadow: 0 24rpx 70rpx rgba(0, 0, 0, 0.18);
}

.command-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin: 0 auto 22rpx;
  background: #e7f7f7;
  border: 8rpx solid #087d91;
  box-sizing: border-box;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1;
}

.command-icon.running {
  border-top-color: #dce8e2;
}

.command-icon.success {
  border-color: #1f8f68;
  background: #e8f7f1;
  color: #1f8f68;
}

.command-icon.failed {
  border-color: #c2573d;
  background: #fff0ed;
  color: #c2573d;
}

.command-title {
  color: #1e2a25;
  font-size: 34rpx;
  font-weight: 600;
  line-height: 44rpx;
}

.command-title.success {
  color: #1f8f68;
}

.command-title.failed {
  color: #c2573d;
}

.command-text {
  min-height: 42rpx;
  margin: 14rpx 0 28rpx;
  color: #5f6f69;
  font-size: 26rpx;
  line-height: 38rpx;
}

.command-steps {
  display: flex;
  justify-content: space-between;
  margin-top: 20rpx;
}

.command-countdown {
  margin-top: 18rpx;
  color: #087d91;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 36rpx;
}

.command-step {
  flex: 1;
  color: #9aa8a3;
  font-size: 22rpx;
  line-height: 30rpx;
}

.command-step.active {
  color: #087d91;
  font-weight: 600;
}

.command-step.active.success {
  color: #1f8f68;
}

.command-step.active.failed {
  color: #c2573d;
}

.command-close {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 76rpx;
  margin-top: 32rpx;
  border-radius: 12rpx;
  background: #087d91;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
}

.command-close.disabled {
  background: #edf3f1;
  color: #87958f;
}

.pin-dialog {
  text-align: left;
}

.pin-dialog .command-title,
.pin-dialog .command-text {
  text-align: center;
}

.pin-input {
  box-sizing: border-box;
  width: 100%;
  height: 84rpx;
  min-height: 84rpx;
  border: 1rpx solid #cddbd5;
  border-radius: 12rpx;
  background: #f8fbfa;
  color: #1e2a25;
  font-size: 32rpx;
  line-height: 84rpx;
  text-align: center;
}

.pin-error {
  margin-top: 12rpx;
  color: #c2573d;
  font-size: 24rpx;
  line-height: 34rpx;
  text-align: center;
}

.pin-actions {
  display: flex;
  column-gap: 18rpx;
  margin-top: 28rpx;
}

.pin-button {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
  height: 76rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.pin-button.secondary {
  background: #edf3f1;
  color: #52615b;
}

.pin-button.primary {
  background: #087d91;
  color: #fff;
}

.inline-input::placeholder {
  color: transparent;
}