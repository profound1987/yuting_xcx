page {
  min-height: 100%;
  background: #f5f8f6;
  color: #18231f;
  font-family: PingFang SC, Helvetica Neue, Arial, sans-serif;
}

.login-page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 64rpx 36rpx 52rpx;
}

.brand-area {
  display: flex;
  align-items: center;
  margin-bottom: 48rpx;
}

.brand-mark {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  background: #1f8f68;
  color: #fff;
  font-size: 48rpx;
  font-weight: 600;
  line-height: 96rpx;
  text-align: center;
  box-shadow: 0 16rpx 32rpx rgba(31, 143, 104, 0.2);
}

.brand-copy {
  margin-left: 24rpx;
}

.brand-name {
  font-size: 46rpx;
  font-weight: 600;
  line-height: 60rpx;
}

.brand-subtitle {
  margin-top: 8rpx;
  color: #66756f;
  font-size: 26rpx;
}

.login-panel {
  box-sizing: border-box;
  width: 100%;
  border: 1rpx solid #e4ece8;
  border-radius: 16rpx;
  background: #fff;
  padding: 34rpx;
  box-shadow: 0 18rpx 44rpx rgba(35, 58, 49, 0.08);
}

.panel-title {
  margin-bottom: 28rpx;
  font-size: 34rpx;
  font-weight: 600;
}

.field {
  box-sizing: border-box;
  min-height: 116rpx;
  margin-bottom: 24rpx;
  padding: 18rpx 22rpx;
  border: 1rpx solid #dde8e2;
  border-radius: 12rpx;
  background: #fbfdfc;
}

.field-label {
  color: #6c7a75;
  font-size: 24rpx;
  line-height: 32rpx;
}

.field-input {
  width: 100%;
  height: 52rpx;
  margin-top: 6rpx;
  color: #18231f;
  font-size: 32rpx;
  line-height: 52rpx;
}

.code-field {
  display: flex;
  align-items: center;
}

.field-main {
  flex: 1;
  min-width: 0;
}

.code-button {
  width: 176rpx;
  height: 68rpx;
  margin-left: 18rpx;
  border-radius: 10rpx;
  background: #e8f4ef;
  color: #1f8f68;
  font-size: 26rpx;
  line-height: 68rpx;
}

.code-button[disabled] {
  background: #eef2f0;
  color: #9aa6a1;
}

.login-button {
  width: 100%;
  height: 88rpx;
  margin-top: 10rpx;
  border-radius: 12rpx;
  background: #1f8f68;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 88rpx;
}

.login-button.is-disabled,
.login-button[disabled] {
  background: #cbd8d2;
  color: #fff;
}

.feature-strip {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  column-gap: 16rpx;
  margin-top: 28rpx;
}

.feature-item {
  min-height: 112rpx;
  border-radius: 14rpx;
  background: #fff;
  border: 1rpx solid #e5ede9;
  text-align: center;
  padding-top: 20rpx;
}

.feature-value {
  color: #1f8f68;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 38rpx;
}

.feature-label {
  margin-top: 6rpx;
  color: #73817b;
  font-size: 23rpx;
}
