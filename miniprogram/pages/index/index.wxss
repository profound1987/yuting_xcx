page {
  min-height: 100%;
  background: #f6faf9;
  color: #18231f;
  font-family: PingFang SC, Helvetica Neue, Arial, sans-serif;
}

.login-page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 52rpx 36rpx 56rpx;
}

.brand-area {
  text-align: center;
  margin-bottom: 34rpx;
}

.brand-logo {
  width: 312rpx;
  height: 312rpx;
  display: block;
  margin: 0 auto;
}

.login-panel {
  box-sizing: border-box;
  width: 100%;
  border: 1rpx solid #e4ece8;
  border-radius: 16rpx;
  background: #fff;
  padding: 34rpx;
  box-shadow: 0 18rpx 44rpx rgba(14, 76, 91, 0.08);
}

.panel-title {
  margin-bottom: 28rpx;
  font-size: 34rpx;
  font-weight: 600;
}

.field {
  box-sizing: border-box;
  min-height: 116rpx;
  margin-bottom: 24rpx;
  padding: 18rpx 22rpx;
  border: 1rpx solid #dde8e2;
  border-radius: 12rpx;
  background: #fbfdfc;
}

.field-label {
  color: #6c7a75;
  font-size: 24rpx;
  line-height: 32rpx;
}

.field-input {
  width: 100%;
  height: 52rpx;
  margin-top: 6rpx;
  color: #18231f;
  font-size: 32rpx;
  line-height: 52rpx;
}

.code-field {
  display: flex;
  align-items: center;
}

.field-main {
  flex: 1;
  min-width: 0;
}

.code-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 176rpx;
  height: 68rpx;
  margin-left: 18rpx;
  padding: 0;
  border-radius: 10rpx;
  background: #e7f7f7;
  color: #087d91;
  font-size: 26rpx;
  line-height: 1;
}

.code-button[disabled] {
  background: #eef2f0;
  color: #9aa6a1;
}

.login-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 88rpx;
  margin-top: 10rpx;
  padding: 0;
  border-radius: 12rpx;
  background: #087d91;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1;
}

.login-button.is-disabled,
.login-button[disabled] {
  background: #cbd8d2;
  color: #fff;
}
