<view class="login-page">
  <view class="brand-area">
    <image class="brand-logo" src="../../images/yutingzhijia.png" mode="aspectFit"></image>
  </view>

  <view class="login-panel">
    <view class="panel-title">手机号登录</view>
    <view class="field">
      <view class="field-label">手机号</view>
      <input class="field-input" type="number" maxlength="11" placeholder="请输入手机号" value="{{phone}}" bindinput="onPhoneInput" />
    </view>
    <view class="field code-field">
      <view class="field-main">
        <view class="field-label">验证码</view>
        <input class="field-input" type="number" maxlength="6" placeholder="请输入验证码" value="{{code}}" bindinput="onCodeInput" />
      </view>
      <button class="code-button" disabled="{{codeButtonDisabled}}" bindtap="sendCode">{{codeButtonText}}</button>
    </view>
    <button class="login-button {{canLogin ? '' : 'is-disabled'}}" disabled="{{!canLogin}}" bindtap="login">登录</button>
  </view>
</view>